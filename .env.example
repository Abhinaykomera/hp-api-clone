# ──────────────────────────────────────────────────────────────
#  MongoDB Connection URI
#  ─────────────────────
#  Option A — Local MongoDB (MongoDB Compass / local mongod):
#  MONGO_URI=mongodb://localhost:27017/hp-api-clone
#
#  Option B — MongoDB Atlas (cloud):
#  MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/hp-api-clone?retryWrites=true&w=majority
# ──────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/hp-api-clone

# ──────────────────────────────────────────────────────────────
#  JWT
# ──────────────────────────────────────────────────────────────
# Use a long, random, unpredictable string in production
JWT_SECRET=your_super_secret_jwt_key_here
# Token expiry (e.g. 7d, 1h, 30m)
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────────────────────────
#  Cloudinary — Image/File Storage
# ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ──────────────────────────────────────────────────────────────
#  Server
# ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ──────────────────────────────────────────────────────────────
#  Resend — Email Notifications
# ──────────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Recipient for "New record added" alerts
NOTIFY_EMAIL=you@example.com

# ──────────────────────────────────────────────────────────────
#  Google Sheets — Webhook Logging
# ──────────────────────────────────────────────────────────────
# Paste the Apps Script doPost web-app URL here
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
