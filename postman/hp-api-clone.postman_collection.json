{
  "info": {
    "name": "HP API Clone",
    "_postman_id": "hp-api-clone-collection-v1",
    "description": "Complete REST API collection for the Harry Potter API Clone.\n\n**Quick start**\n1. Set the `baseUrl` collection variable to `http://localhost:5000` (or your deployed URL).\n2. Run **Login** — the JWT is saved automatically to the `jwt` collection variable.\n3. All protected requests use `{{jwt}}` in their Authorization header — no manual copy-paste needed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "variable": [
    { "key": "baseUrl",  "value": "http://localhost:5000", "type": "string" },
    { "key": "jwt",      "value": "",                      "type": "string" },
    { "key": "houseId",  "value": "",                      "type": "string" },
    { "key": "charId",   "value": "",                      "type": "string" },
    { "key": "studentId","value": "",                      "type": "string" },
    { "key": "staffId",  "value": "",                      "type": "string" }
  ],

  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }]
  },

  "item": [

    {
      "name": "🔐 Auth",
      "item": [

        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@hogwarts.com\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        },

        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "if (json.success && json.token) {",
                  "    pm.collectionVariables.set('jwt', json.token);",
                  "    console.log('✅ JWT saved to collection variable: jwt');",
                  "} else {",
                  "    console.warn('⚠️  Login response did not contain a token:', JSON.stringify(json));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@hogwarts.com\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        },

        {
          "name": "Get Me (protected)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api","auth","me"] }
          },
          "response": []
        },

