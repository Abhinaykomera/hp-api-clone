
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/hp-api-clone?retryWrites=true&w=majority


JWT_SECRET=your_super_secret_jwt_key_here

JWT_EXPIRES_IN=7d


CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


PORT=5000
NODE_ENV=development

# ──────────────────────────────────────────────────────────────
#  Resend — Email Notifications
# ──────────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Recipient for "New record added" alerts
NOTIFY_EMAIL=you@example.com

# ──────────────────────────────────────────────────────────────
#  Google Sheets — Webhook Logging
# ──────────────────────────────────────────────────────────────
# Paste the Apps Script doPost web-app URL here
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ──────────────────────────────────────────────────────────────
#  CORS — Frontend Origin
# ──────────────────────────────────────────────────────────────
# URL of the React frontend (no trailing slash).
# In development, http://localhost:5173 is always allowed automatically.
# Set this to your production frontend URL when deploying.
FRONTEND_URL=https://your-frontend-domain.com
